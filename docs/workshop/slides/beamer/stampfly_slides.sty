% stampfly_slides.sty — Common style for StampFly workshop slides
% StampFly ワークショップスライド共通スタイル

\ProvidesPackage{stampfly_slides}[2025/01/01 StampFly Workshop Slides]

% --- Beamer theme ---
\usetheme{Madrid}
\usecolortheme{default}

% --- StampFly brand colors ---
\definecolor{sfblue}{RGB}{0, 120, 200}
\definecolor{sfdark}{RGB}{0, 60, 100}
\definecolor{sflight}{RGB}{220, 240, 255}
\definecolor{sfgray}{RGB}{80, 80, 80}
\definecolor{sfred}{RGB}{220, 50, 30}
\definecolor{sfgreen}{RGB}{40, 160, 40}

% Apply color to Beamer elements
\setbeamercolor{palette primary}{bg=sfblue, fg=white}
\setbeamercolor{palette secondary}{bg=sfdark, fg=white}
\setbeamercolor{palette tertiary}{bg=sfdark, fg=white}
\setbeamercolor{structure}{fg=sfblue}
\setbeamercolor{title}{fg=white, bg=sfblue}
\setbeamercolor{frametitle}{fg=white, bg=sfblue}
\setbeamercolor{block title}{bg=sfblue!90, fg=white}
\setbeamercolor{block body}{bg=sflight}
\setbeamercolor{block title alerted}{bg=sfred!90, fg=white}
\setbeamercolor{block body alerted}{bg=sfred!8}
\setbeamercolor{block title example}{bg=sfgreen!80, fg=white}
\setbeamercolor{block body example}{bg=sfgreen!8}
\setbeamercolor{item}{fg=sfblue}

% --- Fonts ---
\setbeamerfont{title}{size=\Large, series=\bfseries}
\setbeamerfont{frametitle}{size=\large, series=\bfseries}

% --- Navigation & footer ---
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{footline}{%
  \leavevmode\hbox{%
    \begin{beamercolorbox}[wd=.33\paperwidth,ht=2.5ex,dp=1ex,center]{palette primary}%
      \usebeamerfont{author in head/foot}\insertshortauthor
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=.34\paperwidth,ht=2.5ex,dp=1ex,center]{palette secondary}%
      \usebeamerfont{title in head/foot}\insertshorttitle
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=.33\paperwidth,ht=2.5ex,dp=1ex,right]{palette tertiary}%
      \usebeamerfont{date in head/foot}%
      \insertframenumber{} / \inserttotalframenumber\hspace*{2ex}
    \end{beamercolorbox}%
  }\vskip0pt%
}

% --- Japanese support (LuaLaTeX + luatexja) ---
% Cross-platform font: Hiragino (macOS) → Yu Gothic (Windows) → Noto (Linux)
% クロスプラットフォーム: ヒラギノ (macOS) → 游ゴシック (Windows) → Noto (Linux)
\usepackage{luatexja}
\usepackage[match]{luatexja-fontspec}
\usepackage{ifthen}
\newboolean{jfontset}\setboolean{jfontset}{false}
\IfFontExistsTF{Hiragino Kaku Gothic ProN}{%
  \setmainjfont{Hiragino Kaku Gothic ProN}%
  \setsansjfont{Hiragino Kaku Gothic ProN}%
  \setboolean{jfontset}{true}}{}
\ifthenelse{\boolean{jfontset}}{}{%
  \IfFontExistsTF{Yu Gothic}{%
    \setmainjfont{Yu Gothic}%
    \setsansjfont{Yu Gothic}%
    \setboolean{jfontset}{true}}{}}
\ifthenelse{\boolean{jfontset}}{}{%
  \IfFontExistsTF{Noto Sans CJK JP}{%
    \setmainjfont{Noto Sans CJK JP}%
    \setsansjfont{Noto Sans CJK JP}}{}}

% --- Code listings ---
\usepackage{listings}
\lstdefinestyle{sfcpp}{
  language=C++,
  basicstyle=\ttfamily\scriptsize,
  keywordstyle=\color{sfblue}\bfseries,
  commentstyle=\color{sfgray}\itshape,
  stringstyle=\color{sfgreen},
  numberstyle=\tiny\color{sfgray},
  numbers=left,
  numbersep=5pt,
  aboveskip=4pt,
  belowskip=2pt,
  frame=single,
  framerule=0.5pt,
  rulecolor=\color{sfblue!40},
  backgroundcolor=\color{sflight},
  breaklines=true,
  showstringspaces=false,
  tabsize=4,
  captionpos=b,
  morekeywords={uint8_t, uint32_t, float, void, bool, int},
}
\lstdefinestyle{sfbash}{
  language=bash,
  basicstyle=\ttfamily\footnotesize,
  keywordstyle=\color{sfblue}\bfseries,
  commentstyle=\color{sfgray}\itshape,
  frame=single,
  framerule=0.5pt,
  rulecolor=\color{sfblue!40},
  backgroundcolor=\color{sflight},
  breaklines=true,
  showstringspaces=false,
}
\lstdefinestyle{sfpython}{
  language=Python,
  basicstyle=\ttfamily\scriptsize,
  keywordstyle=\color{sfblue}\bfseries,
  commentstyle=\color{sfgray}\itshape,
  stringstyle=\color{sfgreen},
  numberstyle=\tiny\color{sfgray},
  numbers=left,
  numbersep=5pt,
  aboveskip=4pt,
  belowskip=2pt,
  frame=single,
  framerule=0.5pt,
  rulecolor=\color{sfblue!40},
  backgroundcolor=\color{sflight},
  breaklines=true,
  showstringspaces=false,
  tabsize=4,
  captionpos=b,
  morekeywords={self, True, False, None, as, with},
}
\lstset{style=sfcpp}

% --- tcolorbox + listings code block ---
% Usage: \begin{sflisting}{filename} ... \end{sflisting}
% tcolorbox でタイトルバー付きコードブロックを描画
\usepackage[skins, listings]{tcolorbox}

\newtcblisting{sflisting}[2][]{%
  enhanced,
  listing only,
  listing options={style=sfcpp, #1},
  title={\color{sfblue!80}\phantom{#2}},
  coltitle=sfblue!80,
  colframe=sfblue!80,
  colback=sflight,
  fonttitle=\sffamily\small\bfseries,
  boxrule=0.5pt,
  arc=1.5pt,
  top=2pt, bottom=2pt, left=18pt, right=4pt,
  toptitle=2pt, bottomtitle=2pt,
  overlay={\fill[sfblue!80] (title.south west) rectangle (title.north east);
            \node[anchor=east, white, font=\sffamily\small\bfseries]
              at ([xshift=-4pt]title.east) {#2};},
}

% Backward compat: \codefile still works for cases not yet migrated
\newcommand{\codefile}[1]{%
  \par\noindent
  \colorbox{sfblue!80}{%
    \parbox{\dimexpr\linewidth-2\fboxsep\relax}{%
      \centering\color{white}\sffamily\small\bfseries #1%
    }%
  }\par\vspace{-2.5pt}%
}

% --- Graphics (for including generated PNG diagrams) ---
\usepackage{graphicx}
\usepackage{adjustbox}
\graphicspath{{../images/}}

% --- Standalone (allows \input of standalone TikZ files) ---
\usepackage{standalone}

% --- Math (for equations in slides) ---
\usepackage{amsmath}
\usepackage{bm}

% --- TikZ (for inline diagrams in slides) ---
\usepackage{tikz}
\usetikzlibrary{arrows.meta, positioning, shapes.geometric,
                 fit, decorations.pathmorphing, decorations.pathreplacing,
                 automata, calc, patterns}

% --- pgfplots (for Bode plots and frequency-domain figures) ---
\usepackage{pgfplots}
\pgfplotsset{compat=1.18}
\usepgfplotslibrary{groupplots, fillbetween}

% --- Useful macros ---
\newcommand{\api}[1]{\texttt{\color{sfblue}#1}}
\newcommand{\warn}[1]{\textcolor{sfred}{\textbf{#1}}}
\newcommand{\code}[1]{\texttt{\small #1}}

% --- Lesson command ---
% Usage: \lesson{number}{title_ja}{title_en}
\newcommand{\lesson}[3]{%
  \title{Lesson #1: #2}
  \subtitle{#3}
  \author{StampFly Workshop}
  \date{}
}

% --- Lesson divider slide (section separator) ---
% White background with rounded-rectangle border around title
% Usage: \lessondivider{number}{title_ja}{title_en}
\newcommand{\lessondivider}[3]{%
  \begin{frame}[plain]
    \centering
    \vspace*{\fill}
    \begin{tikzpicture}
      \node[
        rectangle, rounded corners=8pt,
        draw=sfblue, line width=1.5pt,
        fill=sflight,
        inner xsep=20pt, inner ysep=16pt,
        align=center,
        text width=70mm,
      ] {%
        {\fontsize{32}{38}\selectfont\bfseries\textcolor{sfblue}{Lesson #1}}\\[8pt]
        {\Large\bfseries\textcolor{sfdark}{#2}}\\[4pt]
        {\normalsize\textcolor{sfgray}{#3}}%
      };
    \end{tikzpicture}
    \vspace*{\fill}
    \par
    {\small\textcolor{sfgray}{StampFly Workshop}}\par
    \vspace{8mm}
  \end{frame}
}
