<mxfile host="app.diagrams.net" modified="2026-02-15" agent="Claude" version="24.0">
  <diagram id="espnow-dataflow" name="ESP-NOW Dataflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;ESP-NOW Communication Flow&lt;/b&gt;" style="text;html=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="40" as="geometry"/>
        </mxCell>
        <!-- Controller -->
        <mxCell id="ctrl_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;arcSize=10;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="300" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="ctrl_title" value="&lt;b&gt;Controller (TX)&lt;/b&gt;" style="text;html=1;fontSize=16;align=center;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="110" y="90" width="200" height="30" as="geometry"/>
        </mxCell>
        <!-- Sticks -->
        <mxCell id="stick_l" value="&lt;b&gt;Left Stick&lt;/b&gt;&lt;br&gt;Throttle / Yaw" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="stick_r" value="&lt;b&gt;Right Stick&lt;/b&gt;&lt;br&gt;Roll / Pitch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="220" y="140" width="120" height="60" as="geometry"/>
        </mxCell>
        <!-- Buttons -->
        <mxCell id="btn" value="&lt;b&gt;Buttons&lt;/b&gt;&lt;br&gt;ARM / DISARM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="220" width="120" height="50" as="geometry"/>
        </mxCell>
        <!-- ESP-NOW packet -->
        <mxCell id="packet" value="&lt;b&gt;RC Packet&lt;/b&gt;&lt;br&gt;throttle, roll, pitch, yaw&lt;br&gt;armed flag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="290" width="200" height="60" as="geometry"/>
        </mxCell>
        <!-- Arrows to packet -->
        <mxCell id="a1" style="exitX=0.5;exitY=1;entryX=0.25;entryY=0;strokeWidth=1.5;strokeColor=#6c8ebf;" edge="1" source="stick_l" target="packet" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="exitX=0.5;exitY=1;entryX=0.75;entryY=0;strokeWidth=1.5;strokeColor=#6c8ebf;" edge="1" source="stick_r" target="packet" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#6c8ebf;" edge="1" source="btn" target="packet" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Wireless arrow -->
        <mxCell id="wireless" value="&lt;b&gt;ESP-NOW&lt;/b&gt;&lt;br&gt;(2.4 GHz WiFi)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=3;strokeColor=#d6b656;fontSize=12;fontColor=#d6b656;labelBackgroundColor=#FFFFFF;" edge="1" source="packet" target="rx_packet" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- StampFly -->
        <mxCell id="sf_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="360" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="sf_title" value="&lt;b&gt;StampFly (RX)&lt;/b&gt;" style="text;html=1;fontSize=16;align=center;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="650" y="90" width="180" height="30" as="geometry"/>
        </mxCell>
        <!-- Received packet -->
        <mxCell id="rx_packet" value="&lt;b&gt;RC Packet&lt;/b&gt;&lt;br&gt;Received" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="140" width="160" height="50" as="geometry"/>
        </mxCell>
        <!-- API functions -->
        <mxCell id="api1" value="&lt;font face=&quot;monospace&quot;&gt;rc_throttle()&lt;/font&gt;&lt;br&gt;0.0 ~ 1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="220" width="130" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="api2" value="&lt;font face=&quot;monospace&quot;&gt;rc_roll()&lt;/font&gt;&lt;br&gt;-1.0 ~ +1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="730" y="220" width="130" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="api3" value="&lt;font face=&quot;monospace&quot;&gt;rc_pitch() / rc_yaw()&lt;/font&gt;&lt;br&gt;-1.0 ~ +1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="280" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="api4" value="&lt;font face=&quot;monospace&quot;&gt;is_armed()&lt;/font&gt;&lt;br&gt;true / false" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="730" y="280" width="130" height="50" as="geometry"/>
        </mxCell>
        <!-- Arrows from rx to APIs -->
        <mxCell id="b1" style="exitX=0.25;exitY=1;entryX=0.5;entryY=0;strokeWidth=1;strokeColor=#82b366;" edge="1" source="rx_packet" target="api1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2" style="exitX=0.75;exitY=1;entryX=0.5;entryY=0;strokeWidth=1;strokeColor=#82b366;" edge="1" source="rx_packet" target="api2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b3" style="exitX=0.25;exitY=1;entryX=0.5;entryY=0;strokeWidth=1;strokeColor=#82b366;" edge="1" source="api1" target="api3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b4" style="exitX=0.75;exitY=1;entryX=0.5;entryY=0;strokeWidth=1;strokeColor=#82b366;" edge="1" source="api2" target="api4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
