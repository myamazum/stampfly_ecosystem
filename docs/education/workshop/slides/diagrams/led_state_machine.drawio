<mxfile host="app.diagrams.net" modified="2026-02-15" agent="Claude" version="24.0">
  <diagram id="led-state-machine" name="LED State Machine">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;LED State Machine&lt;/b&gt;" style="text;html=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="40" as="geometry"/>
        </mxCell>
        <!-- DISARM state (Red) -->
        <mxCell id="disarm" value="&lt;b&gt;DISARM&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;● RED&lt;/font&gt;&lt;br&gt;&lt;font face=&quot;monospace&quot; size=&quot;1&quot;&gt;led_color(255, 0, 0)&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="150" width="200" height="120" as="geometry"/>
        </mxCell>
        <!-- ARM state (Green) -->
        <mxCell id="arm" value="&lt;b&gt;ARM&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#00AA00&quot;&gt;● GREEN&lt;/font&gt;&lt;br&gt;&lt;font face=&quot;monospace&quot; size=&quot;1&quot;&gt;led_color(0, 255, 0)&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="450" y="150" width="200" height="120" as="geometry"/>
        </mxCell>
        <!-- Low Battery state (Orange blink) -->
        <mxCell id="lowbat" value="&lt;b&gt;LOW BATTERY&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#FF8800&quot;&gt;◉ ORANGE (blink)&lt;/font&gt;&lt;br&gt;&lt;font face=&quot;monospace&quot; size=&quot;1&quot;&gt;led_color(255, 165, 0)&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="150" width="220" height="120" as="geometry"/>
        </mxCell>
        <!-- Initial arrow to DISARM -->
        <mxCell id="init" value="&lt;i&gt;Power ON&lt;/i&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#333333;fontSize=11;" edge="1" target="disarm" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="220" y="100" as="sourcePoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="init_dot" value="" style="ellipse;whiteSpace=wrap;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="213" y="85" width="14" height="14" as="geometry"/>
        </mxCell>
        <!-- DISARM → ARM -->
        <mxCell id="d2a" value="&lt;b&gt;is_armed() == true&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.25;entryX=0;entryY=0.25;strokeWidth=2;strokeColor=#82b366;fontSize=11;fontColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" source="disarm" target="arm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- ARM → DISARM -->
        <mxCell id="a2d" value="&lt;b&gt;is_armed() == false&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0;exitY=0.75;entryX=1;entryY=0.75;strokeWidth=2;strokeColor=#b85450;fontSize=11;fontColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" source="arm" target="disarm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- ARM → Low Battery -->
        <mxCell id="a2l" value="&lt;b&gt;battery_voltage() &amp;lt; 3.5V&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#d6b656;fontSize=11;fontColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" source="arm" target="lowbat" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Voltage labels -->
        <mxCell id="vlabel" value="&lt;b&gt;Battery Voltage Range&lt;/b&gt;&lt;br&gt;4.2V (Full) → 3.7V (Normal) → 3.5V (Warning) → 3.3V (Cutoff)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="250" y="340" width="600" height="40" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
